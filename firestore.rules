rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if the user is an admin.
    // If the admin document does not exist yet (initial setup/bootstrapping), we allow any logged-in user.
    // Otherwise, we verify that the admin is active and has the 'SUPER_ADMIN' role.
    function isAdmin() {
      return isAuthenticated() && (
        !exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (
          get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isActive == true &&
          (
            get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'SUPER_ADMIN' ||
            get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'SCORE_UPDATER'
          )
        )
      );
    }

    // Public read access for all collections (needed by public users/students)
    match /{collection}/{document} {
      allow read: if true;
    }

    // Write access rules for admin-manageable collections
    match /matches/{document} { allow write: if isAdmin(); }
    match /match_events/{document} { allow write: if isAdmin(); }
    match /teams/{document} { allow write: if isAdmin(); }
    match /leagues/{document} { allow write: if isAdmin(); }
    match /players/{document} { allow write: if isAdmin(); }
    match /standings/{document} { allow write: if isAdmin(); }
    match /app_config/{document} { allow write: if isAdmin(); }

    // Admins Collection: Read allowed for auth users, write only manually
    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
  }
}
